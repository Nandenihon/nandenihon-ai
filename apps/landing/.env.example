# MySQL Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# --- Local / Development (SSH Tunnel) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_database_name

# SSH Tunnel Configuration (only needed for remote MySQL in local dev)
SSH_HOST=your.server.ip.or.hostname
SSH_PORT=22
SSH_USERNAME=your_ssh_username
SSH_PASSWORD=your_ssh_password
# Alternatively, use a private key instead of a password:
# SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----

# --- Vercel / Production ---
# Set these in the Vercel dashboard under Environment Variables.
# DB_HOST=your.production.db.host
# DB_PORT=3306
# DB_USER=your_production_db_user
# DB_PASSWORD=your_production_db_password
# DB_NAME=your_production_db_name
